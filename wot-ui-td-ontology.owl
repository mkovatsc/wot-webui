<?xml version="1.0"?>


<!DOCTYPE rdf:RDF [
    <!ENTITY owl "http://www.w3.org/2002/07/owl#" >
    <!ENTITY wotui "http://www.kovtasch.net/wot-webui/wot-ui-td-ontology.owl#" >
    <!ENTITY xsd "http://www.w3.org/2001/XMLSchema#" >
    <!ENTITY rdfs "http://www.w3.org/2000/01/rdf-schema#" >
    <!ENTITY rdf "http://www.w3.org/1999/02/22-rdf-syntax-ns#" >
]>

<rdf:RDF xmlns="http://www.w3c.org/wot/td#"
     xml:base="http://www.w3c.org/wot/td"
     xmlns:wotui="http://www.kovtasch.net/wot-webui/wot-ui-td-ontology.owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.kovtasch.net/wot-webui/wot-ui-td-ontology.owl">
        <owl:versionInfo rdf:datatype="&xsd;decimal">2.2</owl:versionInfo>
        <created rdf:datatype="&xsd;date">2017-06-14</created>
        <wotui:modified rdf:datatype="&xsd;date">2017-06-14</wot2:modified>
        <title rdf:datatype="&xsd;string">Thing Description Model for UI</title>
        <rdfs:comment rdf:datatype="&xsd;string">This ontology describes Components that can be rendered on UI</rdfs:comment>
        <creator rdf:datatype="&xsd;string">W3C Web of Things Interest Group</creator>
        <identifier rdf:datatype="&xsd;anyURI">http://www.w3c.org/wot/td</identifier>
        <owl:imports rdf:resource="http://w3c.github.io/wot/w3c-wot-td-ire.owl"/>
    </owl:Ontology>
</rdf:RDF>
